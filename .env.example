# ── Wingman — Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────────

# Discord Bot Token — from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Application (Client) ID — from Developer Portal > General Information
DISCORD_CLIENT_ID=your_discord_client_id_here

# Gemini API Key — free at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional ──────────────────────────────────────────────────────────────────

# Gemini model (default: gemini-2.0-flash — free tier, 15 RPM, 1M tokens/day)
# Alternatives: gemini-1.5-flash, gemini-1.5-pro, gemini-2.0-flash-thinking-exp
# GEMINI_MODEL=gemini-2.0-flash

# Max output tokens per Gemini response
# GEMINI_MAX_TOKENS=8192

# Guild (server) ID for instant dev command registration
# Leave empty for global commands (takes up to 1 hour to propagate)
# DISCORD_DEV_GUILD_ID=

# SQLite database path (relative to project root)
# DB_PATH=./data/wingman.db

# Minimum score to proactively DM the user their result
# DM_SCORE_THRESHOLD=4.0

# Path to modes directory
# MODES_PATH=./modes

# ── Production ────────────────────────────────────────────────────────────────

# Rate limiting (per user)
# RATE_LIMIT_MAX=5
# RATE_LIMIT_WINDOW_MS=60000

# Health check port (for Docker/Fly.io probes)
# PORT=8080

# Scraper mode: true = headless (servers), false = visible (local dev)
# HEADLESS=true

# Log level: debug | info | warn | error
# LOG_LEVEL=info
